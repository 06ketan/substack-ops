# --- Substack auth (override mcp.json) ---
# SUBSTACK_PUBLICATION_URL=https://ketanchavan.substack.com/
# SUBSTACK_USER_ID=476181629
# SUBSTACK_SESSION_TOKEN=s%3A...

# Override path to mcp.json (defaults to ~/.cursor/mcp.json)
# SUBSTACK_OPS_MCP_PATH=/Users/you/.cursor/mcp.json

# --- LLM (only needed for `reply bulk/review/auto` and `auto daemon`) ---
#
# PRIMARY (recommended): MCP-native. No env vars needed at all. Just install
# the MCP server into Cursor / Claude Desktop / Claude Code:
#   substack-ops mcp install cursor
# and your host LLM does the drafting via propose_reply / confirm_reply.
#
# SECONDARY: subprocess to a host CLI you already pay for. Auto-detected from
# PATH (claude / cursor-agent / codex). Override the command with:
# SUBSTACK_OPS_LLM_CMD="claude --print"
# # use "{prompt}" placeholder if your CLI takes the prompt as an arg, e.g.:
# SUBSTACK_OPS_LLM_CMD="my-cli --prompt {prompt}"
